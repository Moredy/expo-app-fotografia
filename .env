# Clerk Configuration
# Obtenha sua chave no painel do Clerk: https://dashboard.clerk.com/
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsudmxmb3RvZ3JhZmlhLmNvbS5iciQ

# OAuth redirect (opcional). Se definido, o app usa este valor no login Google/Apple.
# Expo Go exemplo: exp://192.168.0.18:8081/--/oauth-callback
# Dev Build exemplo: vitoria-lima-fotografia://oauth-callback
EXPO_PUBLIC_CLERK_OAUTH_REDIRECT_URL=vitoria-lima-fotografia://oauth-callback

# Backend API
# Android Emulator → use http://10.0.2.2:3000
# iOS Simulator    → use http://localhost:3000
# Dispositivo físico → use o IP local da máquina, ex: http://192.168.1.100:3000
# Produção          → substitua pela URL do servidor
EXPO_PUBLIC_API_URL=https://api.vlfotografia.com.br

